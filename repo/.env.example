# Meridian local docker environment
MYSQL_DATABASE=meridian
MYSQL_USER=meridian_user
MYSQL_PASSWORD=meridian_password
MYSQL_ROOT_PASSWORD=meridian_root_password

# Host port mappings (adjust if ports are already used locally)
MYSQL_HOST_PORT=3307
APP_HOST_PORT=18080

# App runtime profile
SPRING_PROFILES_ACTIVE=docker
TZ=Africa/Addis_Ababa

# Bootstrap admin credentials (local dev defaults)
MERIDIAN_BOOTSTRAP_ADMIN_USERNAME=admin
MERIDIAN_BOOTSTRAP_ADMIN_PASSWORD=LocalDevAdmin!2026

# Data encryption key (exactly 32 chars; local dev default)
MERIDIAN_DATA_ENCRYPTION_KEY=MeridianDevSecretKey2026AlphaXYZ

# Report package storage
MERIDIAN_REPORTING_SHARED_FOLDER=/tmp/meridian-report-packages
MERIDIAN_REPORTING_RETENTION_DAYS=90
